# The Empire — local backend (server.js) configuration
# Copy to .env and adjust. Every variable is optional; secure defaults apply.
# The deployed PWA (GitHub Pages) does not use this server.

# HTTP port (default: 3001)
PORT=3001

# Bind address. Default 127.0.0.1 (localhost only).
# Set 0.0.0.0 to expose on your LAN — only on networks you trust.
EMPIRE_HOST=127.0.0.1

# CORS allowlist (comma-separated origins).
# Default: http://localhost:3001, http://127.0.0.1:3001, http://localhost:5173
EMPIRE_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# The agent's shell/code/file-write tools are DISABLED by default (HTTP 403).
# Set to 1 only if you understand the risk of exposing them.
EMPIRE_ENABLE_DANGEROUS_TOOLS=0

# Admin PIN. If unset, a random one-time PIN is printed on first run.
#EMPIRE_ADMIN_PIN=

# Root directory the Files app is allowed to access (default: /storage/emulated/0)
#EMPIRE_ROOT=

# AI provider key for the server-side chat proxy (set any one).
#NVIDIA_API_KEY=
#OPENROUTER_API_KEY=
#AI_API_KEY=

# JWT signing secret. If unset, one is generated and persisted
# to data/.jwt-secret (gitignored) on first run.
#JWT_SECRET=
